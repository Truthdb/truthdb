FROM rust:1-bookworm AS builder

WORKDIR /src

COPY Cargo.toml Cargo.lock ./
COPY src ./src
COPY config ./config
COPY crates ./crates

RUN cargo build --release -p truthdb --bin truthdb \
  && cargo build --release -p truthdb-cli --bin truthdb-cli

FROM debian:bookworm-slim AS runtime

RUN apt-get update \
  && apt-get install -y --no-install-recommends netcat-openbsd ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /src/target/release/truthdb /usr/local/bin/truthdb
COPY --from=builder /src/target/release/truthdb-cli /usr/local/bin/truthdb-cli
COPY docker-repl-entrypoint.sh /usr/local/bin/docker-repl-entrypoint.sh

RUN chmod 0755 /usr/local/bin/docker-repl-entrypoint.sh \
  && mkdir -p /data

ENV STATE_DIRECTORY=/data

ENTRYPOINT ["/usr/local/bin/docker-repl-entrypoint.sh"]
